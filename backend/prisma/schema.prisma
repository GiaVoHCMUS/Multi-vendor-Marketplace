generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- ENUMS ---
enum UserRole {
  ADMIN
  SELLER
  USER
}

enum ShopStatus {
  PENDING
  ACTIVE
  BANNED
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  OUT_OF_STOCK
}

enum OrderStatus {
  PENDING           // đơn hàng vừa tạo
  CONFIRMED         // seller đã nhận đơn
  SHIPPING          // đang giao hàng
  DELIVERED         // đã giao hàng
  CANCELLED         // hủy đơn hàng
}

enum PaymentMethod {
  COD
  VNPAY
}

enum PaymentStatus {
  PENDING           // chưa thanh toán
  COMPLETED         // đã thanh toán
  FAILED
  REFUNDED
}

enum TransactionType {
  PAYMENT
  REFUND
  WITHDRAWAL
}

enum PayoutStatus {
  PENDING     // chưa xử lý
  HOLDING     // đã thanh toán nhưng system đang giữ tiền
  PAID_OUT    // đã trả cho seller
}

// --- MODELS ---

model User {
  id                      String    @id @default(uuid()) @db.Uuid
  email                   String    @unique
  password                String
  role                    UserRole  @default(USER)
  
  // Profile fields gộp chung
  fullName                String
  avatarUrl               String?
  avatarPublicId          String?
  bio                     String?   @db.Text
  
  isVerified              Boolean   @default(false)
  
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  deletedAt               DateTime?   // Xóa mềm    

  // Relationships
  addresses               Address[]
  shop                    Shop?       // 1 người có 0 hoặc 1 Shop
  orderGroups             OrderGroup[]
  reviews                 Review[]

  @@index([role, deletedAt])
  @@map("users")
}

model Address {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @db.Uuid
  receiverName   String
  receiverPhone  String
  province       String
  ward           String
  detailAddress  String   @db.Text
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("addresses")
}

model Shop {
  id            String     @id @default(uuid()) @db.Uuid
  ownerId       String     @unique @db.Uuid
  name          String
  slug          String     @unique
  description   String?    @db.Text
  logoUrl       String?
  logoPublicId  String?
  status        ShopStatus @default(PENDING)
  balance       Decimal    @default(0) @db.Decimal(12, 2)
  
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime? // Xóa mềm

  owner         User       @relation(fields: [ownerId], references: [id])
  products      Product[]
  orders        Order[]
  transactions  Transaction[]

  @@index([ownerId, deletedAt])
  @@index([status, deletedAt])
  @@map("shops")
}

model Category {
  id              Int         @id @default(autoincrement())
  name            String
  slug            String      @unique
  imageUrl        String?
  imagePublicId   String?
  parentId        Int?
  
  // Quan hệ đệ quy (Self-relation)
  parent          Category?   @relation("CategoryToCategory", fields: [parentId], references: [id])
  children        Category[]  @relation("CategoryToCategory")
  products        Product[]

  @@index([parentId])
  @@map("categories")
}

model Product {
  id            String        @id @default(uuid()) @db.Uuid
  shopId        String        @db.Uuid
  categoryId    Int
  name          String
  slug          String        @unique
  description   String?       @db.Text
  price         Decimal       @db.Decimal(12, 2)
  stock         Int           @default(0)
  status        ProductStatus @default(DRAFT)
  averageRating Decimal       @default(0) @db.Decimal(3, 2)
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?    // Xóa mềm

  shop          Shop          @relation(fields: [shopId], references: [id])
  category      Category      @relation(fields: [categoryId], references: [id])
  orderItems    OrderItem[]
  reviews       Review[]
  images        ProductImage[]

  @@unique([shopId, slug])
  @@index([categoryId, price, status])
  @@index([price, status, deletedAt])
  @@index([name, status])                
  @@map("products")
}

model ProductImage {
  id          String    @id @default(uuid()) @db.Uuid
  productId   String    @db.Uuid

  url         String
  publicId    String
  order       Int       @default(0)

  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model OrderGroup {
  id              String        @id @default(uuid()) @db.Uuid
  userId          String        @db.Uuid
  totalAmount     Decimal       @db.Decimal(12, 2)

  paymentMethod   PaymentMethod @default(COD)
  paymentStatus   PaymentStatus @default(PENDING)
  paidAt          DateTime?

  // Thông tin giao hàng dùng chung cho cả đợt thanh toán
  shippingName    String
  shippingPhone   String
  shippingAddress String        @db.Text

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  orders          Order[]       // Một lần thanh toán có thể có nhiều Order (của nhiều Shop)
  user            User          @relation(fields: [userId], references: [id])
  transactions    Transaction[]

  @@index([userId, paymentStatus])
  @@map("order_groups")
}

model Order {
  id              String      @id @default(uuid()) @db.Uuid
  orderGroupId    String      @db.Uuid
  shopId          String      @db.Uuid
  totalAmount     Decimal     @db.Decimal(12, 2) // Tổng tiền của riêng Shop này
  status          OrderStatus @default(PENDING)  // Seller quản lý trạng thái này

  payoutStatus    PayoutStatus  @default(PENDING)
  payoutAt        DateTime?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  orderGroup      OrderGroup  @relation(fields: [orderGroupId], references: [id], onDelete: Cascade)
  shop            Shop        @relation(fields: [shopId], references: [id])
  orderItems      OrderItem[]
  transactions    Transaction[]
  
  @@map("orders")
}

model OrderItem {
  id              String   @id @default(uuid()) @db.Uuid
  orderId         String   @db.Uuid
  productId       String   @db.Uuid
  quantity        Int
  priceAtPurchase Decimal  @db.Decimal(12, 2)

  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product  @relation(fields: [productId], references: [id])

  @@index([orderId, productId])
  @@map("order_items")
}

model Review {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  productId String   @db.Uuid
  rating    Int
  comment   String?  @db.Text
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])

  @@index([productId]) 
  @@map("reviews")
}

model Transaction {
  id              String          @id @default(uuid()) @db.Uuid
  orderGroupId    String?         @db.Uuid
  orderId         String?         @db.Uuid
  shopId          String?         @db.Uuid

  amount          Decimal         @db.Decimal(12, 2)
  
  type            TransactionType
  status          PaymentStatus   @default(COMPLETED)

  description     String?
  createdAt       DateTime        @default(now())

  orderGroup      OrderGroup?       @relation(fields: [orderGroupId], references: [id])
  order           Order?            @relation(fields: [orderId], references: [id])
  shop            Shop?             @relation(fields: [shopId], references: [id])

  @@index([orderGroupId])
  @@index([orderId])
  @@index([shopId])
  @@map("transactions")
}

// Bảng này không có quan hệ với bảng nào khác
model SystemStat {
  id              Int      @id @default(autoincrement())
  date            DateTime @unique // Thống kê theo ngày
  totalRevenue    Decimal  @default(0)
  totalOrders     Int      @default(0)
  totalNewUsers   Int      @default(0)
  totalNewShops   Int      @default(0)
  platformFee     Decimal  @default(0) // Tiền sàn thu được (ví dụ 5% mỗi đơn)
  
  @@map("system_stats")
}
