generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- ENUMS ---
enum UserRole {
  ADMIN
  SELLER
  USER
}

enum ShopStatus {
  PENDING
  ACTIVE
  BANNED
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  OUT_OF_STOCK
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPING
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  COD
  STRIPE
  MOCK_PAYMENT
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum TransactionType {
  PAYMENT
  REFUND
  WITHDRAWAL
}

// --- MODELS ---

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique
  password      String
  role          UserRole  @default(USER)
  
  // Profile fields gộp chung
  fullName      String
  avatarUrl     String?
  bio           String?   @db.Text
  
  isVerified    Boolean   @default(false)
  refreshToken  String?   @db.Text
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime? // Xóa mềm    

  // Relationships
  addresses     Address[]
  shop          Shop?     // 1 người có 0 hoặc 1 Shop
  orders        Order[]
  reviews       Review[]

  @@index([role, deletedAt])
  @@map("users")
}

model Address {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @db.Uuid
  receiverName   String
  receiverPhone  String
  province       String
  ward           String
  detailAddress  String   @db.Text
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("addresses")
}

model Shop {
  id          String     @id @default(uuid()) @db.Uuid
  ownerId     String     @unique @db.Uuid
  name        String
  slug        String     @unique
  description String?    @db.Text
  logoUrl     String?
  status      ShopStatus @default(PENDING)
  balance     Decimal    @default(0) @db.Decimal(12, 2)
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime? // Xóa mềm

  owner       User       @relation(fields: [ownerId], references: [id])
  products    Product[]
  orderItems  OrderItem[]

  @@index([status, deletedAt])
  @@map("shops")
}

model Category {
  id        Int         @id @default(autoincrement())
  name      String
  slug      String      @unique
  imageUrl  String?
  parentId  Int?
  
  // Quan hệ đệ quy (Self-relation)
  parent    Category?   @relation("CategoryToCategory", fields: [parentId], references: [id])
  children  Category[]  @relation("CategoryToCategory")
  products  Product[]

  @@index([ parentId])
  @@map("categories")
}

model Product {
  id            String        @id @default(uuid()) @db.Uuid
  shopId        String        @db.Uuid
  categoryId    Int
  name          String
  slug          String
  description   String?       @db.Text
  price         Decimal       @db.Decimal(12, 2)
  stock         Int           @default(0)
  images        String[]      // Postgres Array
  status        ProductStatus @default(DRAFT)
  averageRating Decimal       @default(0) @db.Decimal(3, 2)
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?    // Xóa mềm

  shop          Shop          @relation(fields: [shopId], references: [id])
  category      Category      @relation(fields: [categoryId], references: [id])
  orderItems    OrderItem[]
  reviews       Review[]

  @@unique([shopId, slug])
  @@index([categoryId, price, status])
  @@index([price, status, deletedAt])
  @@index([name])                
  @@map("products")
}

model Order {
  id                  String        @id @default(uuid()) @db.Uuid
  userId              String        @db.Uuid
  totalAmount         Decimal       @db.Decimal(12, 2)
  status              OrderStatus   @default(PENDING)
  
  // Snapshot thông tin giao hàng
  shippingName        String
  shippingPhone       String
  shippingAddressFull String        @db.Text
  
  paymentMethod       PaymentMethod @default(MOCK_PAYMENT)
  paymentStatus       PaymentStatus @default(PENDING)
  
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  user                User          @relation(fields: [userId], references: [id])
  orderItems          OrderItem[]
  transaction         Transaction?

  @@index([userId, status])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id              String   @id @default(uuid()) @db.Uuid
  orderId         String   @db.Uuid
  productId       String   @db.Uuid
  shopId          String   @db.Uuid
  quantity        Int
  priceAtPurchase Decimal  @db.Decimal(12, 2)

  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product  @relation(fields: [productId], references: [id])
  shop            Shop     @relation(fields: [shopId], references: [id])

  @@index([orderId])
  @@index([shopId])
  @@map("order_items")
}

model Review {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  productId String   @db.Uuid
  rating    Int
  comment   String?  @db.Text
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])

  @@index([productId]) 
  @@map("reviews")
}

model Transaction {
  id        String          @id @default(uuid()) @db.Uuid
  orderId   String          @unique @db.Uuid
  amount    Decimal         @db.Decimal(12, 2)
  type      TransactionType
  status    PaymentStatus   @default(COMPLETED)
  createdAt DateTime        @default(now())

  order     Order           @relation(fields: [orderId], references: [id])

  @@map("transactions")
}