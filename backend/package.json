{
  "name": "marketplace-backend",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --watch src/docs -r tsconfig-paths/register src/server.ts",
    "build": "prisma generate && tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "worker:dev": "ts-node-dev -r tsconfig-paths/register src/jobs/workers/index.ts",
    "worker": "node dist/jobs/workers/index.js",
    "test": "jest --no-cache",
    "test:watch": "jest --watchAll --no-cache",
    "test:ci": "jest --ci --coverage --no-cache",
    "tree": "npx tree -l 4 -I --ignore 'node_modules' --ignore 'coverage'",
    "test:load": "k6 run tests/load/product-test.js",
    "test:load:summary": "k6 run --summary-export=load-report.json src/shared/tests/load/product_test.js",
    "db:seed": "ts-node src/scripts/seed.ts",
    "db:export-product-idxs": "ts-node src/scripts/export-product-ids.ts"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@bull-board/api": "^6.20.6",
    "@bull-board/express": "^6.20.6",
    "@prisma/client": "^6.19.2",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.71.0",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "ejs": "^5.0.1",
    "express": "^5.2.1",
    "http-status-codes": "^2.3.0",
    "ioredis": "^5.9.3",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.2",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "rate-limiter-flexible": "^11.0.0",
    "redis": "^5.11.0",
    "slugify": "^1.6.8",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tsconfig-paths": "^4.2.0",
    "uuid": "^14.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.4.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^7.0.11",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "prisma": "^6.12.0",
    "ts-jest": "^29.4.9",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
